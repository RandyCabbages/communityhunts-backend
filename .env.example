# Discord OAuth
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_CALLBACK_URL=https://your-railway-url.up.railway.app/auth/discord/callback

# Session
SESSION_SECRET=your_long_random_secret_here

# Database (Railway provides this automatically)
DATABASE_URL=your_postgres_url

# Frontend URL (for CORS + redirects)
FRONTEND_URL=https://your-vercel-url.vercel.app

# Twitch (for live detection)
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret

# Optional overrides
ADMINS=bean,randycabbage,randy cabbage,mcflurry,mihallimou,missingiscool,cuda
VIP_HOSTS=bean,mcflurry,mihallimou,missingiscool,cuda,randycabbage
